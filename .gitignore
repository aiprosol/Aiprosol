# Aiprosol monorepo · .gitignore
# Covers /web (Next.js app), /build (content library), /scripts, /audits, and ad-hoc top-level artifacts.

# ────────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit these
# ────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local
# Explicitly allow examples (no real secrets, safe template)
!.env.example
!**/.env.example

# Cron / IndexNow / signing secrets if any drift outside .env
*.pem
*.key
*-secret.json
*.credentials.json

# ────────────────────────────────────────────────────────────────────────
# Node / Next.js
# ────────────────────────────────────────────────────────────────────────
node_modules/
.npm/
.yarn/
.pnpm-store/
**/node_modules/

# Next.js build output
.next/
out/
**/.next/
**/out/

# TypeScript incremental build info
*.tsbuildinfo
next-env.d.ts

# ────────────────────────────────────────────────────────────────────────
# Vercel
# ────────────────────────────────────────────────────────────────────────
.vercel/
**/.vercel/

# ────────────────────────────────────────────────────────────────────────
# OS junk
# ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ────────────────────────────────────────────────────────────────────────
# Editor / IDE
# ────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ────────────────────────────────────────────────────────────────────────
# Logs / coverage / temp
# ────────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
.nyc_output/
/tmp/
*.tmp

# ────────────────────────────────────────────────────────────────────────
# Claude / agent session state (local-only)
# ────────────────────────────────────────────────────────────────────────
.claude/

# ────────────────────────────────────────────────────────────────────────
# Big binaries we don't want to bloat the repo with
# (Reels production renders + downloaded stock footage, if any)
# ────────────────────────────────────────────────────────────────────────
*.mov
*.mp4
*.webm
# But DO commit the brand-test particle render — it's small and reused
!build/reels/01/particle-a-logo-test.mp4

# ────────────────────────────────────────────────────────────────────────
# Python / scripts
# ────────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ────────────────────────────────────────────────────────────────────────
# Misc local-only
# ────────────────────────────────────────────────────────────────────────
*.local
.cache/
