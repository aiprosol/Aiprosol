          {
            "node": "Gmail — create draft",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Gmail — create draft": {
      "main": [
        [
          {
            "node": "Slack — notify rep",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
