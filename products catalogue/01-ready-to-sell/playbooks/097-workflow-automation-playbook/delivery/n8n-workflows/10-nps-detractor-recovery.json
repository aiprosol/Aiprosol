{
  "name": "Aiprosol — NPS detractor recovery (branching by score)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "nps-response"
      },
      "id": "ff1f1487-0460-4255-8c5b-e3fe9990c0ec",
