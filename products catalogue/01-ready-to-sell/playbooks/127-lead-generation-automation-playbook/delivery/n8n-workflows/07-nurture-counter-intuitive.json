        840,
        300
      ]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={ $('Find leads at day ' + str(5) + ').first().json.email }",
        "subject": "=The one thing most people miss about {topic}",
        "message": "={{ $json.message.content }}"
