    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const cutoff = Date.now() - 5*24*60*60*1000; return $input.all().filter(i => Math.abs(new Date(i.json.captured_at).getTime() - cutoff) < 24*60*60*1000 && i.json.lead_tier === 'warm');"
      },
      "id": "4ec822c9-00f9-4352-8584-388c3fd8eb18",
      "name": "Filter to today's send batch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "resource": "chat",
        "modelId": {
          "value": "gpt-4o"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Write Email 3 of a 5-touch nurture sequence. Brief: Counter-intuitive angle on their problem. One specific case study by name. 90-sec video link. CTA: book a 15-min call.. Tone: warm, specific, no marketing fluff. 150-250 words."
            },
            {
              "role": "user",
              "content": "=Lead: role={{ $json.role }}, industry={{ $json.industry }}, stated problem={{ $json.primary_problem }}"
            }
          ]
        }
      },
      "id": "023b3f4f-d648-41fe-9665-cb4c737c212f",
      "name": "AI-personalise body",
