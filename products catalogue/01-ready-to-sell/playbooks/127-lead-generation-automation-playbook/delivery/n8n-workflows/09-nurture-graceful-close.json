    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const cutoff = Date.now() - 21*24*60*60*1000; return $input.all().filter(i => Math.abs(new Date(i.json.captured_at).getTime() - cutoff) < 24*60*60*1000 && i.json.lead_tier === 'warm');"
      },
      "id": "104c7019-9be2-4c9b-936f-ed2ddfb0a9a1",
      "name": "Filter to today's send batch",
