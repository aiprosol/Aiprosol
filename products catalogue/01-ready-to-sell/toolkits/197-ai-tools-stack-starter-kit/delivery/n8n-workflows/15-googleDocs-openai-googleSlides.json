{
  "name": "Aiprosol Stack — Google Doc → OpenAI → Google Slides deck",
  "nodes": [
    {
      "parameters": {
        "event": "fileUpdated",
        "folderToWatch": {
          "__rl": true,
          "value": "DOC_FOLDER_ID"
        }
      },
      "id": "b49c93c4-01ba-4e5e-a08a-14712160315c",
      "name": "Doc updated",
      "type": "n8n-nodes-base.googleDriveTrigger",
      "typeVersion": 1,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "operation": "get",
        "documentURL": "={{ $json.webViewLink }}"
      },
      "id": "783d960b-86ec-49c7-98bb-742bfec775b0",
      "name": "Read doc text",
      "type": "n8n-nodes-base.googleDocs",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "resource": "chat",
        "modelId": {
          "value": "gpt-4o"
        },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Convert this doc into a 10-slide deck. Return JSON {slides: [{title, bullets}]}"
            },
            {
              "role": "user",
              "content": "={{ $json.text }}"
            }
          ]
        },
        "options": {
          "responseFormat": "json_object"
        }
      },
      "id": "9e68aed5-1458-4b70-8159-a2db2f977618",
      "name": "Structure slides",
