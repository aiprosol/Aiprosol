      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "operation": "createPresentation",
        "title": "=Deck — {{ $('Doc updated').first().json.name }}"
      },
      "id": "fb979efc-8bc1-4d94-a1e4-ba695f91c34e",
      "name": "Create Slides",
      "type": "n8n-nodes-base.googleSlides",
      "typeVersion": 1,
      "position": [
        840,
        300
      ]
    }
  ],
  "connections": {
