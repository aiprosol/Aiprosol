# ─────────────────────────────────────────────────────────────────────────
# AIPROSOL · Environment Variables
# Copy to .env.local for development. Set via Vercel Dashboard for production.
# ─────────────────────────────────────────────────────────────────────────

# ─── Public site URL (used in metadata + emails) ───
NEXT_PUBLIC_SITE_URL=https://aiprosol.com

# ─── Groq · Arora chat widget LLM ───
# Default model is llama-3.3-70b-versatile (smart + fast on Groq).
# Override with any supported model: https://console.groq.com/docs/models
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Studio Copilot · operator personal assistant (Claude side) ───
# Powers the floating assistant inside /studio. The model toggle there picks
# between Claude (this) and Groq (above). Leave ANTHROPIC_API_KEY blank to hide
# the Claude option and run Copilot on Groq only.
# Default model is Sonnet (cost/latency); set claude-opus-4-8 for max capability.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Studio · Growth Intelligence (Funnel tab) ───
# Server-side read of the PostHog events already tracked client-side.
# POSTHOG_API_KEY is a *personal* API key (not the NEXT_PUBLIC_ write key).
# Find the project ID in PostHog → Project settings.
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
# Revenue tab reads STRIPE_SECRET_KEY (set above). Optional: VERCEL_TOKEN +
# VERCEL_PROJECT_ID + VERCEL_TEAM_ID to show deploys inline in the System tab.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ─── Stripe · payments ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend · transactional email ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Arora at Aiprosol <hello@aiprosol.com>

# ─── Auth · magic-link sign-in ───
# Used to HMAC-sign session cookies + magic-link tokens. Generate with:
#   node -e "console.log(crypto.randomBytes(48).toString('base64url'))"
# Rotate to invalidate every session.
SESSION_SECRET=

# Used to sign download tokens emailed by the Stripe webhook. Same generation
# command as SESSION_SECRET. Rotate to invalidate all outstanding download links.
DOWNLOAD_SECRET=

# ─── Auth · Google OAuth (optional) ───
# To enable "Continue with Google":
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a new OAuth 2.0 Client ID (type: Web application)
#   3. Authorised redirect URI: https://aiprosol.com/api/auth/google/callback
#      (also add http://localhost:3000/api/auth/google/callback for dev)
#   4. Paste client ID + secret below
# When both are unset, the Google button is hidden — magic-link still works.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Optional · Zapier webhook for new leads ───
ZAPIER_LEAD_WEBHOOK=

# ─── Optional · Wix CMS export (migration only) ───
# Used by migrate/export-wix.ts. Not needed at runtime.
WIX_API_KEY=
WIX_SITE_ID=fb912f58-d70f-4919-bb13-a4b5761de943
WIX_ACCOUNT_ID=

# ─── Optional · Analytics ───
NEXT_PUBLIC_GA_ID=
